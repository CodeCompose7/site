{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/__/auth/session",
        "function": "sessionLogin"
      },
      {
        "source": "/slides/**",
        "function": "authMiddleware"
      },
      {
        "source": "/ko/courses/lmm/**",
        "function": "authMiddleware"
      },
      {
        "source": "/ko/courses/lmm/detail/**",
        "function": "authMiddleware"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
