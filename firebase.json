{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/__/auth/session",
        "function": {
          "functionId": "sessionLogin",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/slides/**",
        "function": {
          "functionId": "authMiddleware",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/ko/courses/lmm/detail/**",
        "function": {
          "functionId": "authMiddleware",
          "region": "asia-northeast3"
        }
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
